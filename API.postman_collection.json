    {
      "name": "04 - Create Listing",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('create listing returns 201', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "pm.test('created listing has expected category and id', () => {",
              "  pm.expect(json.listing).to.have.property('id');",
              "  pm.expect(json.listing.category).to.eql('Calculator');",
              "});",
              "pm.collectionVariables.set('listingId', json.listing.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "title",
              "value": "Casio fx-991ES Plus",
              "type": "text"
            },
            {
              "key": "price",
              "value": "800",
              "type": "text"
            },
            {
              "key": "category",
              "value": "Calculator",
              "type": "text"
            },
            {
              "key": "description",
              "value": "Used for one semester. Created from Postman API validation.",
              "type": "text"
            },
            {
              "key": "image",
              "type": "file",
              "src": [],
              "disabled": true,
              "description": "Optional: enable and attach an image file under 3 MB to validate image upload behavior."
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/listings",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "listings"
          ]
        }
      },
      "response": []
    },
    {
      "name": "05 - Get Listing By ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('get listing by id returns 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('listing id matches collection variable', () => {",
              "  pm.expect(String(json.listing.id)).to.eql(String(pm.collectionVariables.get('listingId')));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/listings/{{listingId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "listings",
            "{{listingId}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "06 - Search and Filter Listings",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('search/filter returns 200', () => pm.response.to.have.status(200));",
              "const listings = pm.response.json().listings;",
              "pm.test('filtered response contains calculator listing', () => {",
              "  pm.expect(listings.some((item) => String(item.id) === String(pm.collectionVariables.get('listingId')))).to.eql(true);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/listings?search=calculator&category=Calculator",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "listings"
          ],
          "query": [
            {
              "key": "search",
              "value": "calculator"
            },
            {
              "key": "category",
              "value": "Calculator"
            }
          ]
        }
      },
      "response": []
    },
