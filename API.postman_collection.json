{
  "info": {
    "_postman_id": "6f2a29d5-75d1-4f17-8a65-1d5c6d3a0001",
    "name": "Campus Marketplace API",
    "description": "Postman collection for validating the 12 REST APIs in the Campus Marketplace MVP. Run requests in order so auth cookies and collection variables are reused across the workflow.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Register User",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('testEmail', `postman.${Date.now()}@example.com`);",
              "pm.collectionVariables.set('testPassword', 'password123');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('register returns 201', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "pm.test('registered user has id and email', () => {",
              "  pm.expect(json.user).to.have.property('id');",
              "  pm.expect(json.user.email).to.eql(pm.collectionVariables.get('testEmail'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Postman Student\",\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"phone\": \"9800000000\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "register"
          ]
        }
      },
      "response": []
    },
